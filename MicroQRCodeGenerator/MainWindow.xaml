<Window x:Class="MicroQRCodeGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MicroQRCodeGenerator"
        mc:Ignorable="d"
        Title="QR Code Generator" Height="750" Width="700"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="30">
            <!-- Header -->
            <TextBlock Text="QR Code Generator" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#333333"
                       Margin="0,0,0,10"/>
            
            <Separator Height="2" Background="#E0E0E0" Margin="0,0,0,20"/>

            <!-- Tab Control for Single/Batch Mode -->
            <TabControl Name="ModeTabControl" Margin="0,0,0,20" Background="White">
                <!-- Single Mode Tab -->
                <TabItem Header="단일 생성" Background="White">
                    <StackPanel Margin="15" Orientation="Vertical">
                        <!-- Input Section -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="QR 코드 번호" 
                                           FontSize="14" 
                                           Foreground="#555555"
                                           Margin="0,0,0,8"/>
                                <TextBox Name="QRCodeInput" 
                                         Height="40"
                                         Padding="12,10"
                                         FontSize="14"
                                         BorderThickness="1"
                                         BorderBrush="#CCCCCC"
                                         Background="White"
                                         Foreground="#333333"/>
                            </StackPanel>

                            <Button Name="GenerateButton" 
                                    Grid.Column="1"
                                    Content="생성" 
                                    Click="GenerateButton_Click" 
                                    Margin="10,0,0,0"
                                    Height="40"
                                    VerticalAlignment="Bottom"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource {x:Type Button}}"/>

                            <Button Name="SaveButton" 
                                    Grid.Column="2"
                                    Content="저장" 
                                    Click="SaveButton_Click" 
                                    Margin="10,0,0,0"
                                    Height="40"
                                    VerticalAlignment="Bottom"
                                    Background="#2196F3"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource {x:Type Button}}"/>
                        </Grid>

                        <!-- QR Code Display Section -->
                        <Border BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                Background="White"
                                Padding="20"
                                CornerRadius="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="300">
                                <Image Name="QRCodeImage" 
                                       Height="250" 
                                       Width="250"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <!-- Batch Mode Tab -->
                <TabItem Header="대량 생성 (CSV)" Background="White">
                    <StackPanel Margin="15" Orientation="Vertical">
                        <!-- CSV Input -->
                        <TextBlock Text="CSV 입력 (쉼표 또는 줄 바꿈으로 구분)" 
                                   FontSize="14" 
                                   Foreground="#555555"
                                   Margin="0,0,0,8"/>
                        <TextBox Name="CsvInput" 
                                 Height="120"
                                 Padding="12,10"
                                 FontSize="12"
                                 BorderThickness="1"
                                 BorderBrush="#CCCCCC"
                                 Background="White"
                                 Foreground="#333333"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"/>

                        <TextBlock Text="예시: 23142, 23143&#10;또는 각 번호를 한 줄씩" 
                                   FontSize="12" 
                                   Foreground="#999999"
                                   Margin="0,5,0,15"
                                   FontStyle="Italic"/>

                        <!-- Buttons -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Button Name="LoadCsvButton" 
                                    Grid.Column="1"
                                    Content="CSV 파일 열기" 
                                    Click="LoadCsvButton_Click" 
                                    Margin="10,0,0,0"
                                    Height="40"
                                    Background="#FF9800"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource {x:Type Button}}"/>

                            <Button Name="GenerateBatchButton" 
                                    Grid.Column="2"
                                    Content="일괄 생성 및 저장" 
                                    Click="GenerateBatchButton_Click" 
                                    Margin="10,0,0,0"
                                    Height="40"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource {x:Type Button}}"/>
                        </Grid>

                        <!-- Progress and Info -->
                        <ProgressBar Name="ProgressBar" 
                                     Height="8" 
                                     Margin="0,0,0,10"
                                     Foreground="#4CAF50"/>
                        
                        <TextBlock Name="StatusText" 
                                   FontSize="12" 
                                   Foreground="#666666"
                                   TextWrapping="Wrap"
                                   MinHeight="40"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </StackPanel>
    </Grid>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border Name="Border" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" Margin="0,0,1,0">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,8"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
